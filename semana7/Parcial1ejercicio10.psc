Algoritmo mayor_menor
	
	Definir num1, num2 Como Entero
	
	Escribir "Ingresar el primer numero"
	leer num1
	
	Escribir "Ingrear el segundo numero"
	leer num2
	
	Si num1 > num2 Entonces
		Escribir "Mayor ", num1
		Escribir "Menor ", num2
	SiNo
		si num2 > num1 Entonces
			Escribir "Mayor ", num2
			Escribir "Menor ", num1
			
		Fin Si
		fin si
FinAlgoritmo
