Algoritmo pedir_numer0s_entre_1_10
	
	Definir num Como Entero
	
	Escribir "Ingresar numero entre 1 a 10"
	leer num 
	
	Mientras num >= 1 y num <= 10 Hacer
		Escribir "Numero valido"
		Escribir "Ingrese otro numero"
		leer num
	Fin Mientras
	
	Escribir "Numero invalido. Fin del programa"
FinAlgoritmo
