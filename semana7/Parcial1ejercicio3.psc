Algoritmo Del1_al_7_DiadelaSemana
	
	Definir num Como Entero
	
	escribir "Ingresar un numero del 1 al 7"
	leer num
	
	Segun num Hacer
		1:
		escribir "Lunes"
		2:
			Escribir "Martes"
		3:
			Escribir "Miercoles"
		4:
			Escribir "Jueves"
		5:
			Escribir "Viernes"
		6:
			Escribir "Sabado"
		7: 
			Escribir "Domingo"
		De Otro Modo:
			Escribir "Numero no valido"
	Fin Segun
	
	
FinAlgoritmo
